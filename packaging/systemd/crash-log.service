[Unit]
Description=Log unclean shutdowns (crash detection)
Documentation=file:///opt/uconsole/scripts/util/crash-log.sh
DefaultDependencies=no
After=local-fs.target
Before=sysinit.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/opt/uconsole/scripts/util/crash-log.sh boot
ExecStop=/opt/uconsole/scripts/util/crash-log.sh stop

[Install]
WantedBy=sysinit.target
