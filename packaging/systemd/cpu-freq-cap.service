[Unit]
Description=Cap CPU frequency to 1.2GHz to reduce battery voltage sag
Documentation=file:///opt/uconsole/scripts/power/cpu-freq-cap.sh
DefaultDependencies=no
After=local-fs.target
Before=sysinit.target

[Service]
Type=oneshot
ExecStart=/opt/uconsole/scripts/power/cpu-freq-cap.sh

[Install]
WantedBy=sysinit.target
