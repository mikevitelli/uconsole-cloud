#!/bin/bash
set -e

# ── Helpers ───────────────────────────────────────────────────────
# Resolve the real (non-root) user who invoked the install.

get_real_user() {
    local user="${SUDO_USER:-$(logname 2>/dev/null || whoami)}"
    if [ "$user" = "root" ]; then
        user="$(getent passwd | awk -F: '$3 >= 1000 && $3 < 60000 {print $1; exit}')"
    fi
    echo "$user"
}

get_real_home() {
    getent passwd "$1" | cut -d: -f6
}

# ── Main ──────────────────────────────────────────────────────────

case "$1" in
    configure)
        REAL_USER="$(get_real_user)"
        REAL_HOME="$(get_real_home "$REAL_USER")"

        if [ -z "$REAL_USER" ] || [ "$REAL_USER" = "root" ]; then
            echo "WARNING: Could not determine non-root user. Some steps skipped." >&2
        fi

        # Create system config directory
        mkdir -p /etc/uconsole/ssl

        # Copy default config if user config doesn't exist (never overwrite)
        if [ ! -f /etc/uconsole/uconsole.conf ]; then
            cp /opt/uconsole/share/defaults/uconsole.conf.default /etc/uconsole/uconsole.conf
        fi

        # Create user config directory
        if [ -n "$REAL_HOME" ] && [ -d "$REAL_HOME" ]; then
            mkdir -p "${REAL_HOME}/.config/uconsole"
            chown "$REAL_USER":"$(id -gn "$REAL_USER")" "${REAL_HOME}/.config/uconsole"
        fi

        # Generate self-signed SSL cert if not present
        if [ ! -f /etc/uconsole/ssl/uconsole.crt ]; then
            openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
                -keyout /etc/uconsole/ssl/uconsole.key \
                -out /etc/uconsole/ssl/uconsole.crt \
                -subj "/CN=uconsole.local" \
                -addext "subjectAltName=DNS:uconsole.local,DNS:uconsole,IP:127.0.0.1" \
                2>/dev/null
            chgrp www-data /etc/uconsole/ssl/uconsole.key
            chmod 640 /etc/uconsole/ssl/uconsole.key
        fi

        # Make all scripts executable
        find /opt/uconsole/ -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
        find /opt/uconsole/ -name "*.py" -exec chmod +x {} \; 2>/dev/null || true
        chmod +x /opt/uconsole/bin/* 2>/dev/null || true

        # Inject actual username into all service units
        if [ -n "$REAL_USER" ] && [ "$REAL_USER" != "root" ]; then
            for unit in /etc/systemd/system/uconsole-*.service; do
                [ -f "$unit" ] && sed -i "s/UCONSOLE_USER/${REAL_USER}/g" "$unit"
            done
        fi

        # Enable nginx site
        if [ -f /etc/nginx/sites-available/uconsole-webdash ]; then
            ln -sf /etc/nginx/sites-available/uconsole-webdash /etc/nginx/sites-enabled/uconsole-webdash
            nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null || true
        fi

        # Reload systemd to pick up new unit files (but do NOT enable or start)
        systemctl daemon-reload 2>/dev/null || true

        # Detect and stop old user-level webdash service
        if [ -n "$REAL_HOME" ]; then
            OLD_SVC="${REAL_HOME}/.config/systemd/user/webdash.service"
            if [ -f "$OLD_SVC" ]; then
                echo "Migrating from user-level webdash to system service..."
                su - "$REAL_USER" -c "systemctl --user stop webdash.service 2>/dev/null; systemctl --user disable webdash.service 2>/dev/null" || true
                echo "Old user-level webdash.service stopped and disabled."
            fi

            # Migrate status.env from old location if needed
            OLD_ENV="${REAL_HOME}/.config/uconsole/status.env"
            if [ -f "$OLD_ENV" ] && [ ! -f /etc/uconsole/status.env ]; then
                cp "$OLD_ENV" /etc/uconsole/status.env
                chown "$REAL_USER":"$(id -gn "$REAL_USER")" /etc/uconsole/status.env
                chmod 600 /etc/uconsole/status.env
                echo "Migrated cloud config from ${OLD_ENV} to /etc/uconsole/status.env"
            fi
        fi

        # Add Ctrl+` keybind for console TUI if labwc is installed
        if [ -n "$REAL_HOME" ]; then
            LABWC_RC="${REAL_HOME}/.config/labwc/rc.xml"
            if [ -f "$LABWC_RC" ] && ! grep -q 'C-grave' "$LABWC_RC" 2>/dev/null; then
                SNIPPET="/opt/uconsole/share/defaults/labwc-keybind.xml"
                if [ -f "$SNIPPET" ]; then
                    sed -i '/<keyboard>/r '"$SNIPPET" "$LABWC_RC"
                    echo "Added Ctrl+\` keybind for console TUI"
                fi
            fi
        fi

        echo ""
        echo "========================================"
        echo "  uconsole-cloud installed!"
        echo ""
        echo "  Run 'uconsole setup' to configure"
        echo "  your device."
        echo ""
        echo "  Commands:"
        echo "    uconsole setup    Configure device"
        echo "    uconsole doctor   Check system health"
        echo "    uconsole help     See all commands"
        echo "========================================"
        echo ""
        ;;
esac
