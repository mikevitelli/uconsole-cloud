#!/bin/bash
set -e

case "$1" in
    configure)
        # Create system config directory
        mkdir -p /etc/uconsole/ssl

        # Copy default config if user config doesn't exist (never overwrite)
        if [ ! -f /etc/uconsole/uconsole.conf ]; then
            cp /opt/uconsole/share/defaults/uconsole.conf.default /etc/uconsole/uconsole.conf
        fi

        # Create user config directory for the installing user
        REAL_USER="${SUDO_USER:-$(whoami)}"
        REAL_HOME="$(getent passwd "$REAL_USER" | cut -d: -f6)"
        if [ -n "$REAL_HOME" ] && [ -d "$REAL_HOME" ]; then
            mkdir -p "${REAL_HOME}/.config/uconsole"
            chown "$REAL_USER":"$(id -gn "$REAL_USER")" "${REAL_HOME}/.config/uconsole"
        fi

        # Generate self-signed SSL cert if not present
        if [ ! -f /etc/uconsole/ssl/uconsole.crt ]; then
            openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
                -keyout /etc/uconsole/ssl/uconsole.key \
                -out /etc/uconsole/ssl/uconsole.crt \
                -subj "/CN=uconsole.local" 2>/dev/null
            chmod 600 /etc/uconsole/ssl/uconsole.key
        fi

        # Create runtime data directory
        mkdir -p /var/lib/uconsole
        chmod 700 /var/lib/uconsole

        # Make all scripts executable
        find /opt/uconsole/ -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
        find /opt/uconsole/ -name "*.py" -exec chmod +x {} \; 2>/dev/null || true
        chmod +x /opt/uconsole/bin/* 2>/dev/null || true

        # Reload systemd to pick up new unit files (but do NOT enable or start)
        systemctl daemon-reload

        echo ""
        echo "========================================"
        echo "  uconsole-tools installed!"
        echo ""
        echo "  Run 'uconsole setup' to configure"
        echo "  your device."
        echo ""
        echo "  Commands:"
        echo "    uconsole setup    Configure device"
        echo "    uconsole doctor   Check system health"
        echo "    uconsole help     See all commands"
        echo "========================================"
        echo ""
        ;;
esac
