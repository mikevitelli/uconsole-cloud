#!/bin/bash
# uconsole CLI — manage your uconsole.cloud device connection
# Usage: uconsole <command>
set -euo pipefail

BASE_URL="${BASE_URL:-https://uconsole.cloud}"

# ── Path detection ───────────────────────────────────────
# .deb package installs to /opt/uconsole; curl install uses ~/
if [ -d /opt/uconsole/scripts ]; then
  INSTALL_MODE="package"
  CONFIG_DIR="/etc/uconsole"
  ENV_FILE="/etc/uconsole/status.env"
  SCRIPTS_DIR="/opt/uconsole/scripts"
else
  INSTALL_MODE="standalone"
  CONFIG_DIR="${HOME}/.config/uconsole"
  ENV_FILE="${CONFIG_DIR}/status.env"
  SCRIPTS_DIR="${HOME}/scripts"
fi

# ── Helpers ──────────────────────────────────────────────

die() { echo "ERROR: $1" >&2; exit 1; }

# Extract a JSON string value: json_val '{"k":"v"}' k → v
json_val() {
  local json="$1" key="$2"
  echo "$json" | grep -o "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | head -1 | sed 's/.*:.*"\(.*\)"/\1/'
}

# Extract a JSON number value: json_num '{"k":600}' k → 600
json_num() {
  local json="$1" key="$2"
  echo "$json" | grep -o "\"${key}\"[[:space:]]*:[[:space:]]*[0-9]*" | head -1 | sed 's/.*:[[:space:]]*//'
}

# Show QR code if qrencode is available
show_qr() {
  local url="$1"
  if command -v qrencode &>/dev/null; then
    echo ""
    echo "  Scan this QR code:"
    echo ""
    qrencode -t UTF8 -m 2 "$url" | sed 's/^/  /'
  fi
}

# Run a command with sudo in package mode, directly in standalone
maybe_sudo() {
  if [ "$INSTALL_MODE" = "package" ]; then
    sudo "$@"
  else
    "$@"
  fi
}

# Run journalctl with --user in standalone mode
run_journalctl() {
  local args=()
  [ "$INSTALL_MODE" = "standalone" ] && args+=(--user)
  args+=("$@")
  journalctl "${args[@]}"
}

# Manage systemd timers/services (system in package mode, user in standalone)
manage_timer() {
  local action="$1" unit="$2"
  if [ "$INSTALL_MODE" = "package" ]; then
    sudo systemctl "$action" "$unit" 2>/dev/null
  else
    systemctl --user "$action" "$unit" 2>/dev/null
  fi
}

# Resolve push-status.sh path
get_push_script() {
  if [ "$INSTALL_MODE" = "package" ]; then
    echo "${SCRIPTS_DIR}/system/push-status.sh"
  else
    # Try well-known locations in order
    local candidates=(
      "${SCRIPTS_DIR}/push-status.sh"
      "${HOME}/uconsole/scripts/system/push-status.sh"
      "${HOME}/uconsole/scripts/push-status.sh"
    )
    for path in "${candidates[@]}"; do
      if [ -x "$path" ]; then
        echo "$path"
        return 0
      fi
    done
    echo "${SCRIPTS_DIR}/push-status.sh"
  fi
}

# Map friendly service name to systemd unit
service_to_unit() {
  case "$1" in
    webdash) echo "uconsole-webdash" ;;
    status)  echo "uconsole-status" ;;
    backup)  echo "uconsole-backup" ;;
    update)  echo "uconsole-update" ;;
    *) die "Unknown service: $1. Valid: webdash, status, backup, update" ;;
  esac
}

# ── Commands ─────────────────────────────────────────────

cmd_setup() {
  if [ "$INSTALL_MODE" = "package" ]; then
    if [ -x /opt/uconsole/bin/uconsole-setup ]; then
      exec /opt/uconsole/bin/uconsole-setup "$@"
    else
      echo "Setup wizard not found. Run 'uconsole link' for cloud linking only."
      return 1
    fi
  else
    # Standalone mode: no wizard available, do cloud linking
    cmd_link "$@"
  fi
}

cmd_link() {
  # Clean up stale cron entries from old standalone installs (package mode uses systemd timer)
  if [ "$INSTALL_MODE" = "package" ] && crontab -l 2>/dev/null | grep -q "push-status.sh"; then
    crontab -l 2>/dev/null | grep -v "push-status.sh" | crontab -
    echo "Removed stale cron job (package mode uses systemd timer)"
  fi

  # Check for existing config
  local env_readable=false
  if maybe_sudo test -f "${ENV_FILE}" 2>/dev/null; then
    env_readable=true
    eval "$(maybe_sudo cat "${ENV_FILE}" 2>/dev/null)"
  fi
  if [ "$env_readable" = true ]; then
    echo "This device is already linked."
    echo "  Repo:  ${DEVICE_REPO:-unknown}"
    echo "  Token: ${DEVICE_TOKEN:0:8}...${DEVICE_TOKEN: -4}"
    echo ""
    printf "Re-link with a new token? This will replace your current config. [y/N] "
    read -r CONFIRM
    case "$CONFIRM" in
      [yY]|[yY][eE][sS]) ;;
      *) echo "Cancelled."; return 0 ;;
    esac
    echo ""
  fi

  echo "Requesting device code..."
  RESPONSE=$(curl -fsSL -X POST "${BASE_URL}/api/device/code")
  CODE=$(json_val "$RESPONSE" "code")
  SECRET=$(json_val "$RESPONSE" "secret")
  EXPIRES=$(json_num "$RESPONSE" "expiresIn")

  if [ -z "$CODE" ] || [ -z "$SECRET" ]; then
    die "Failed to get device code. Check your network connection."
  fi

  LINK_URL="${BASE_URL}/link?code=${CODE}"
  MINS=$((EXPIRES / 60))

  # Show QR code (scannable link with code pre-filled)
  show_qr "$LINK_URL"

  echo ""
  echo "  Or enter this code at ${BASE_URL}/link:"
  echo ""
  echo "  ┌────────────┐"
  echo "  │   ${CODE}   │"
  echo "  └────────────┘"
  echo ""
  echo "  Waiting... (expires in ${MINS}:00)"

  # Poll every 3 seconds
  ELAPSED=0
  while [ "$ELAPSED" -lt "$EXPIRES" ]; do
    sleep 3
    ELAPSED=$((ELAPSED + 3))

    POLL=$(curl -fsSL "${BASE_URL}/api/device/poll/${SECRET}" 2>/dev/null || echo '{"status":"error"}')
    STATUS=$(json_val "$POLL" "status")

    if [ "$STATUS" = "confirmed" ]; then
      DEVICE_TOKEN=$(json_val "$POLL" "deviceToken")
      REPO=$(json_val "$POLL" "repo")

      echo ""
      echo "Device confirmed!"
      echo "Linked to ${REPO}"

      # Write config
      if [ "$INSTALL_MODE" = "package" ]; then
        sudo tee "${ENV_FILE}" > /dev/null << EOF
DEVICE_API_URL="${BASE_URL}/api/device/push"
DEVICE_TOKEN="${DEVICE_TOKEN}"
DEVICE_REPO="${REPO}"
EOF
        sudo chmod 600 "${ENV_FILE}"
      else
        mkdir -p "${CONFIG_DIR}"
        cat > "${ENV_FILE}" << EOF
DEVICE_API_URL="${BASE_URL}/api/device/push"
DEVICE_TOKEN="${DEVICE_TOKEN}"
DEVICE_REPO="${REPO}"
EOF
        chmod 600 "${ENV_FILE}"
      fi
      echo "Config written to ${ENV_FILE}"

      if [ "$INSTALL_MODE" = "package" ]; then
        # Package mode: system services are already installed by postinst.
        # Restart the timer so it picks up the new env file.
        manage_timer restart uconsole-status.timer || true
        echo "Status timer restarted"
      else
        # Standalone mode: create user services or cron
        # Remove old cron entry if present (migration)
        if crontab -l 2>/dev/null | grep -q "push-status.sh"; then
          crontab -l 2>/dev/null | grep -v "push-status.sh" | crontab -
          echo "Removed old cron job"
        fi

        SYSTEMD_DIR="${HOME}/.config/systemd/user"
        if command -v systemctl &>/dev/null && [ -d /run/systemd/system ]; then
          mkdir -p "${SYSTEMD_DIR}"
          local push_path
          push_path="$(get_push_script)"

          cat > "${SYSTEMD_DIR}/uconsole-status.service" << SVCEOF
[Unit]
Description=Push uConsole status to uconsole.cloud
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=${push_path}
Environment=HOME=${HOME}
WorkingDirectory=${HOME}
SVCEOF

          cat > "${SYSTEMD_DIR}/uconsole-status.timer" << TMREOF
[Unit]
Description=Push uConsole status every 5 minutes

[Timer]
OnBootSec=1min
OnUnitActiveSec=5min
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
TMREOF

          systemctl --user daemon-reload
          systemctl --user enable --now uconsole-status.timer
          echo "Systemd timer enabled (every 5 minutes)"
        else
          # Fallback: cron (non-systemd systems)
          local push_path
          push_path="$(get_push_script)"
          CRON_CMD="*/5 * * * * ${push_path} >> /tmp/uconsole-push.log 2>&1"
          ( crontab -l 2>/dev/null | grep -v "push-status.sh" ; echo "$CRON_CMD" ) | crontab -
          echo "Cron job set (every 5 minutes)"
        fi
      fi

      # First push
      local push_script
      push_script="$(get_push_script)"
      if [ -x "$push_script" ]; then
        echo "Running first status push..."
        "$push_script" && echo "First status pushed!" || echo "Push failed (will retry via timer)"
      fi

      echo ""
      echo "View your dashboard: ${BASE_URL}"
      return 0
    fi

    if [ "$STATUS" = "error" ]; then
      # Code may have expired or been consumed — re-check
      :
    fi

    # Show countdown
    REMAINING=$((EXPIRES - ELAPSED))
    R_MINS=$((REMAINING / 60))
    R_SECS=$((REMAINING % 60))
    printf "\r  Waiting... (expires in %d:%02d) " "$R_MINS" "$R_SECS"
  done

  echo ""
  die "Code expired. Run 'uconsole link' to try again."
}

cmd_push() {
  if [ ! -f "${ENV_FILE}" ]; then
    die "Not configured. Run 'uconsole setup' first."
  fi
  local push_script
  push_script="$(get_push_script)"
  if [ ! -x "$push_script" ]; then
    die "push-status.sh not found. Run 'uconsole update' to download."
  fi
  "$push_script"
}

cmd_status() {
  if [ ! -f "${ENV_FILE}" ]; then
    echo "Status: not configured"
    echo "Run 'uconsole setup' to link your device."
    return 0
  fi

  # shellcheck source=/dev/null
  source "${ENV_FILE}"
  echo "Status: configured (${INSTALL_MODE})"
  echo "  API:   ${DEVICE_API_URL:-not set}"
  echo "  Token: ${DEVICE_TOKEN:0:8}...${DEVICE_TOKEN: -4}"
  echo "  Repo:  ${DEVICE_REPO:-not set}"

  # Check scheduling
  if manage_timer is-active uconsole-status.timer; then
    local timer_type="system"
    [ "$INSTALL_MODE" = "standalone" ] && timer_type="user"
    echo "  Timer: active (${timer_type}, every 5 min)"
  elif crontab -l 2>/dev/null | grep -q "push-status.sh"; then
    echo "  Cron:  active (every 5 min)"
  else
    echo "  Timer: not set"
  fi

  # Last push
  if command -v journalctl &>/dev/null; then
    LAST_PUSH=$(run_journalctl -u uconsole-status -n 1 --no-pager -q 2>/dev/null | tail -1)
    if [ -n "$LAST_PUSH" ]; then
      echo "  Last:  ${LAST_PUSH}"
    fi
  elif [ -f /tmp/uconsole-push.log ]; then
    LAST=$(tail -1 /tmp/uconsole-push.log)
    echo "  Last:  ${LAST}"
  fi
}

cmd_unlink() {
  if [ "$INSTALL_MODE" = "package" ]; then
    # Package mode: don't touch system services, just remove config
    if [ -f "${ENV_FILE}" ]; then
      maybe_sudo rm -f "${ENV_FILE}"
      echo "Removed device config"
    fi
    echo "Device unlinked. Services still installed (managed by package)."
    echo "Run 'uconsole link' to reconnect."
  else
    # Standalone mode: stop user services and clean up
    manage_timer stop uconsole-status.timer || true
    manage_timer disable uconsole-status.timer || true
    echo "Stopped systemd timer"

    SYSTEMD_DIR="${HOME}/.config/systemd/user"
    rm -f "${SYSTEMD_DIR}/uconsole-status.service" "${SYSTEMD_DIR}/uconsole-status.timer"
    systemctl --user daemon-reload 2>/dev/null || true

    if crontab -l 2>/dev/null | grep -q "push-status.sh"; then
      crontab -l 2>/dev/null | grep -v "push-status.sh" | crontab -
      echo "Removed cron job"
    fi

    if [ -f "${ENV_FILE}" ]; then
      rm -f "${ENV_FILE}"
      echo "Removed config"
    fi

    echo "Device unlinked. Run 'uconsole link' to reconnect."
  fi
}

cmd_update() {
  if [ "$INSTALL_MODE" = "package" ]; then
    echo "Installed via .deb package. Update with:"
    echo "  sudo apt update && sudo apt upgrade uconsole-cloud"
    return 0
  fi

  echo "Updating scripts..."
  mkdir -p "${SCRIPTS_DIR}" "${HOME}/.local/bin"

  curl -fsSL "${BASE_URL}/api/scripts/uconsole" -o "${HOME}/.local/bin/uconsole"
  chmod +x "${HOME}/.local/bin/uconsole"

  curl -fsSL "${BASE_URL}/api/scripts/push-status.sh" -o "${SCRIPTS_DIR}/push-status.sh"
  chmod +x "${SCRIPTS_DIR}/push-status.sh"

  echo "Updated to latest versions."
}

cmd_passwd() {
  if [ "$INSTALL_MODE" = "package" ]; then
    if [ -x /opt/uconsole/bin/uconsole-passwd ]; then
      exec /opt/uconsole/bin/uconsole-passwd "$@"
    else
      die "uconsole-passwd not found"
    fi
  else
    die "Password management requires package install"
  fi
}

cmd_doctor() {
  echo "uconsole doctor (${INSTALL_MODE} mode)"
  echo ""
  local pass=0 fail=0

  # Config
  local env_exists=false
  if maybe_sudo test -f "${ENV_FILE}" 2>/dev/null; then
    env_exists=true
  fi
  if [ "$env_exists" = true ]; then
    echo "  [OK] Config file exists (${ENV_FILE})"
    pass=$((pass + 1))
    PERMS=$(maybe_sudo stat -c '%a' "${ENV_FILE}" 2>/dev/null || stat -f '%Lp' "${ENV_FILE}" 2>/dev/null)
    if [ "$PERMS" = "600" ]; then
      echo "  [OK] Config permissions (600)"
      pass=$((pass + 1))
    else
      echo "  [!!] Config permissions are ${PERMS}, should be 600"
      fail=$((fail + 1))
    fi
  else
    echo "  [!!] Config file missing — run 'uconsole setup'"
    fail=$((fail + 1))
  fi

  # Push script
  local push_script
  push_script="$(get_push_script)"
  if [ -x "$push_script" ]; then
    echo "  [OK] push-status.sh found ($push_script)"
    pass=$((pass + 1))
  else
    echo "  [!!] push-status.sh not found or not executable"
    fail=$((fail + 1))
  fi

  # Systemd services
  if [ "$INSTALL_MODE" = "package" ]; then
    for svc in uconsole-webdash.service uconsole-status.timer uconsole-backup.timer uconsole-update.timer; do
      if systemctl is-active --quiet "$svc" 2>/dev/null; then
        echo "  [OK] ${svc} active"
        pass=$((pass + 1))
      elif systemctl is-enabled --quiet "$svc" 2>/dev/null; then
        echo "  [--] ${svc} enabled but not running"
      else
        echo "  [!!] ${svc} not enabled"
        fail=$((fail + 1))
      fi
    done

    # Verify webdash actually responds (catches crash loops, bad User=, etc.)
    if systemctl is-active --quiet uconsole-webdash.service 2>/dev/null; then
      if curl -sk --max-time 3 -o /dev/null -w '' https://localhost 2>/dev/null; then
        echo "  [OK] webdash responding on HTTPS"
        pass=$((pass + 1))
      else
        echo "  [!!] webdash service active but not responding — check: uconsole logs webdash"
        fail=$((fail + 1))
      fi
    fi

    # Dev mode check
    local dev_conf="/etc/systemd/system/uconsole-webdash.service.d/dev.conf"
    if [ -f "$dev_conf" ]; then
      local dev_path
      dev_path=$(grep -o 'WorkingDirectory=.*' "$dev_conf" 2>/dev/null | sed 's/WorkingDirectory=//' || echo "unknown")
      echo "  [--] Dev mode active — webdash running from ${dev_path}"
    fi
  else
    if manage_timer is-active uconsole-status.timer; then
      echo "  [OK] Status timer active"
      pass=$((pass + 1))
    elif crontab -l 2>/dev/null | grep -q "push-status.sh"; then
      echo "  [OK] Cron job active (legacy)"
      pass=$((pass + 1))
    else
      echo "  [!!] No timer or cron job for status push"
      fail=$((fail + 1))
    fi

    if command -v systemctl &>/dev/null && systemctl --user is-active --quiet webdash.service 2>/dev/null; then
      echo "  [OK] Webdash running"
      pass=$((pass + 1))
    else
      echo "  [--] Webdash not running"
    fi
  fi

  # nginx (package mode)
  if [ "$INSTALL_MODE" = "package" ]; then
    if [ -L /etc/nginx/sites-enabled/uconsole-webdash ]; then
      echo "  [OK] nginx site enabled"
      pass=$((pass + 1))
    else
      echo "  [!!] nginx site not enabled"
      fail=$((fail + 1))
    fi

    if [ -f /etc/uconsole/ssl/uconsole.crt ]; then
      echo "  [OK] SSL certificate exists"
      pass=$((pass + 1))
    else
      echo "  [!!] SSL certificate missing"
      fail=$((fail + 1))
    fi
  fi

  # mDNS / avahi
  if command -v avahi-daemon &>/dev/null; then
    if systemctl is-active --quiet avahi-daemon 2>/dev/null; then
      echo "  [OK] avahi-daemon active"
      pass=$((pass + 1))
      if avahi-resolve -n uconsole.local &>/dev/null; then
        echo "  [OK] uconsole.local resolves"
        pass=$((pass + 1))
      else
        echo "  [!!] uconsole.local does not resolve"
        fail=$((fail + 1))
      fi
    else
      echo "  [!!] avahi-daemon not running — uconsole.local won't work"
      fail=$((fail + 1))
    fi
  else
    echo "  [--] avahi not installed (uconsole.local won't resolve)"
  fi

  # Last push
  if command -v journalctl &>/dev/null; then
    LAST_PUSH=$(run_journalctl -u uconsole-status -n 1 --no-pager -q 2>/dev/null | tail -1)
    if [ -n "$LAST_PUSH" ]; then
      echo "  [OK] Last push: ${LAST_PUSH}"
      pass=$((pass + 1))
    fi
  elif [ -f /tmp/uconsole-push.log ]; then
    echo "  [OK] Last push: $(tail -1 /tmp/uconsole-push.log)"
    pass=$((pass + 1))
  fi

  # Network
  if curl -s --max-time 5 -o /dev/null "${BASE_URL}/api/health"; then
    echo "  [OK] uconsole.cloud reachable"
    pass=$((pass + 1))
  else
    echo "  [!!] Cannot reach uconsole.cloud"
    fail=$((fail + 1))
  fi

  # Migration checks (package mode)
  if [ "$INSTALL_MODE" = "package" ]; then
    OLD_ENV="${HOME}/.config/uconsole/status.env"
    if [ -f "$OLD_ENV" ] && [ ! -f "${ENV_FILE}" ]; then
      echo "  [!!] Found old config at ${OLD_ENV} — run 'sudo cp ${OLD_ENV} ${ENV_FILE} && sudo chmod 600 ${ENV_FILE}' to migrate"
      fail=$((fail + 1))
    fi
    if systemctl --user is-active --quiet webdash.service 2>/dev/null; then
      echo "  [!!] Old user-level webdash.service still running — run 'systemctl --user stop webdash && systemctl --user disable webdash'"
      fail=$((fail + 1))
    fi
    if crontab -l 2>/dev/null | grep -q "push-status.sh"; then
      echo "  [!!] Stale cron job found — push-status running via both cron and systemd timer"
      echo "       Fix: uconsole link (auto-cleans cron) or: crontab -l | grep -v push-status | crontab -"
      fail=$((fail + 1))
    fi
  fi

  echo ""
  echo "  ${pass} passed, ${fail} failed"
}

cmd_logs() {
  local service="" follow=false

  for arg in "$@"; do
    case "$arg" in
      -f|--follow) follow=true ;;
      *) service="$arg" ;;
    esac
  done

  # Default to webdash
  [ -z "$service" ] && service="webdash"

  local unit
  unit="$(service_to_unit "$service")"

  local args=(-u "$unit" --no-pager)
  if [ "$follow" = true ]; then
    args+=(-f)
  else
    args+=(-n 50)
  fi

  run_journalctl "${args[@]}"
}

cmd_restore() {
  REPO_DIR="${HOME}/uconsole"

  if [ ! -d "${REPO_DIR}" ]; then
    echo "Backup repo not found at ${REPO_DIR}"
    echo ""
    echo "To restore, first clone your backup repo:"
    echo "  gh repo clone <user>/uconsole ~/uconsole"
    echo "Then run 'uconsole restore' again."
    return 1
  fi

  if [ ! -f "${REPO_DIR}/restore.sh" ]; then
    echo "restore.sh not found in ${REPO_DIR}"
    return 1
  fi

  echo "Found backup repo at ${REPO_DIR}"
  printf "Run restore.sh --yes? [y/N] "
  read -r CONFIRM
  case "$CONFIRM" in
    [yY]|[yY][eE][sS]) ;;
    *) echo "Cancelled."; return 0 ;;
  esac

  cd "${REPO_DIR}" && bash ./restore.sh --yes

  echo ""
  if [ ! -f "${ENV_FILE}" ]; then
    echo "Restore complete. To connect to uconsole.cloud:"
    echo "  uconsole link"
  else
    echo "Restore complete. Cloud connection already configured."
  fi
}

cmd_version() {
  if [ -f /opt/uconsole/VERSION ]; then
    local ver
    ver=$(cat /opt/uconsole/VERSION)
    if [ -f /etc/systemd/system/uconsole-webdash.service.d/dev.conf ]; then
      echo "uconsole-cloud ${ver} (dev)"
    else
      echo "uconsole-cloud ${ver}"
    fi
  else
    echo "uconsole-cloud (standalone — no package installed)"
  fi
}

cmd_help() {
  echo "uconsole — manage your uconsole.cloud device"
  echo ""
  echo "Commands:"
  echo "  setup    Configure device (full wizard)"
  echo "  link     Link device to uconsole.cloud"
  echo "  push     Push status now"
  echo "  status   Show current config and last push"
  echo "  logs     Show service logs (webdash, status, backup, update)"
  echo "  passwd   Change webdash password"
  echo "  doctor   Diagnose connectivity and configuration"
  echo "  restore  Run restore.sh from backup repo"
  echo "  unlink   Remove config and stop timer"
  echo "  update   Re-download latest scripts (or upgrade .deb)"
  echo "  version  Show version"
  echo "  help     Show this help"
  echo ""
  echo "Install mode: ${INSTALL_MODE}"
  echo "Config:       ${ENV_FILE}"
  echo "Scripts:      ${SCRIPTS_DIR}"
}

# ── Main ─────────────────────────────────────────────────

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  setup)   cmd_setup "$@" ;;
  link)    cmd_link "$@" ;;
  push)    cmd_push ;;
  status)  cmd_status ;;
  logs)    cmd_logs "$@" ;;
  passwd)  cmd_passwd "$@" ;;
  doctor)  cmd_doctor ;;
  restore) cmd_restore ;;
  unlink)  cmd_unlink ;;
  update)  cmd_update ;;
  version|--version|-v) cmd_version ;;
  help|--help|-h) cmd_help ;;
  *) echo "Unknown command: ${COMMAND}"; cmd_help; exit 1 ;;
esac
