#!/bin/bash
# uconsole CLI — manage your uconsole.cloud device connection
# Usage: uconsole <command>
set -euo pipefail

BASE_URL="${BASE_URL:-https://uconsole.cloud}"
CONFIG_DIR="${HOME}/.config/uconsole"
ENV_FILE="${CONFIG_DIR}/status.env"
SCRIPTS_DIR="${HOME}/scripts"

# ── Helpers ──────────────────────────────────────────────

die() { echo "ERROR: $1" >&2; exit 1; }

# Extract a JSON string value: json_val '{"k":"v"}' k → v
json_val() {
  local json="$1" key="$2"
  echo "$json" | grep -o "\"${key}\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | head -1 | sed 's/.*:.*"\(.*\)"/\1/'
}

# Extract a JSON number value: json_num '{"k":600}' k → 600
json_num() {
  local json="$1" key="$2"
  echo "$json" | grep -o "\"${key}\"[[:space:]]*:[[:space:]]*[0-9]*" | head -1 | sed 's/.*:[[:space:]]*//'
}

# ── Commands ─────────────────────────────────────────────

cmd_setup() {
  # Check for existing config
  if [ -f "${ENV_FILE}" ]; then
    # shellcheck source=/dev/null
    source "${ENV_FILE}"
    echo "This device is already linked."
    echo "  Repo:  ${DEVICE_REPO:-unknown}"
    echo "  Token: ${DEVICE_TOKEN:0:8}...${DEVICE_TOKEN: -4}"
    echo ""
    printf "Re-link with a new token? This will replace your current config. [y/N] "
    read -r CONFIRM
    case "$CONFIRM" in
      [yY]|[yY][eE][sS]) ;;
      *) echo "Cancelled."; return 0 ;;
    esac
    echo ""
  fi

  echo "Requesting device code..."
  RESPONSE=$(curl -fsSL -X POST "${BASE_URL}/api/device/code")
  CODE=$(json_val "$RESPONSE" "code")
  SECRET=$(json_val "$RESPONSE" "secret")
  EXPIRES=$(json_num "$RESPONSE" "expiresIn")

  if [ -z "$CODE" ] || [ -z "$SECRET" ]; then
    die "Failed to get device code. Check your network connection."
  fi

  MINS=$((EXPIRES / 60))
  echo ""
  echo "Enter this code at ${BASE_URL}/link"
  echo ""
  echo "  ┌──────────────┐"
  echo "  │  ${CODE}   │"
  echo "  └──────────────┘"
  echo ""
  echo "Waiting for confirmation... (expires in ${MINS}:00)"

  # Poll every 3 seconds
  ELAPSED=0
  while [ "$ELAPSED" -lt "$EXPIRES" ]; do
    sleep 3
    ELAPSED=$((ELAPSED + 3))

    POLL=$(curl -fsSL "${BASE_URL}/api/device/poll/${SECRET}" 2>/dev/null || echo '{"status":"error"}')
    STATUS=$(json_val "$POLL" "status")

    if [ "$STATUS" = "confirmed" ]; then
      DEVICE_TOKEN=$(json_val "$POLL" "deviceToken")
      REPO=$(json_val "$POLL" "repo")

      echo ""
      echo "Device confirmed!"
      echo "Linked to ${REPO}"

      # Write config
      mkdir -p "${CONFIG_DIR}"
      cat > "${ENV_FILE}" << EOF
DEVICE_API_URL="${BASE_URL}/api/device/push"
DEVICE_TOKEN="${DEVICE_TOKEN}"
DEVICE_REPO="${REPO}"
EOF
      chmod 600 "${ENV_FILE}"
      echo "Config written to ${ENV_FILE}"

      # Setup status push timer (prefer systemd, fallback to cron)
      # Remove old cron entry if present (migration)
      if crontab -l 2>/dev/null | grep -q "push-status.sh"; then
        crontab -l 2>/dev/null | grep -v "push-status.sh" | crontab -
        echo "Removed old cron job"
      fi

      SYSTEMD_DIR="${HOME}/.config/systemd/user"
      if command -v systemctl &>/dev/null && [ -d /run/systemd/system ]; then
        mkdir -p "${SYSTEMD_DIR}"
        # Determine push-status.sh path (prefer backup repo copy if present)
        PUSH_SCRIPT="${SCRIPTS_DIR}/push-status.sh"
        [ -x "${HOME}/uconsole/scripts/push-status.sh" ] && PUSH_SCRIPT="${HOME}/uconsole/scripts/push-status.sh"

        cat > "${SYSTEMD_DIR}/uconsole-status.service" << SVCEOF
[Unit]
Description=Push uConsole status to uconsole.cloud
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=${PUSH_SCRIPT}
Environment=HOME=${HOME}
WorkingDirectory=${HOME}
SVCEOF

        cat > "${SYSTEMD_DIR}/uconsole-status.timer" << TMREOF
[Unit]
Description=Push uConsole status every 5 minutes

[Timer]
OnBootSec=1min
OnUnitActiveSec=5min
AccuracySec=30s
Persistent=true

[Install]
WantedBy=timers.target
TMREOF

        systemctl --user daemon-reload
        systemctl --user enable --now uconsole-status.timer
        echo "Systemd timer enabled (every 5 minutes)"
      else
        # Fallback: cron (non-systemd systems)
        CRON_CMD="*/5 * * * * ${SCRIPTS_DIR}/push-status.sh >> /tmp/uconsole-push.log 2>&1"
        ( crontab -l 2>/dev/null | grep -v "push-status.sh" ; echo "$CRON_CMD" ) | crontab -
        echo "Cron job set (every 5 minutes)"
      fi

      # First push
      if [ -x "$PUSH_SCRIPT" ]; then
        echo "Running first status push..."
        "$PUSH_SCRIPT" && echo "First status pushed!" || echo "Push failed (will retry via timer)"
      fi

      echo ""
      echo "View your dashboard: ${BASE_URL}"
      return 0
    fi

    if [ "$STATUS" = "error" ]; then
      # Code may have expired or been consumed — re-check
      :
    fi

    # Show countdown
    REMAINING=$((EXPIRES - ELAPSED))
    R_MINS=$((REMAINING / 60))
    R_SECS=$((REMAINING % 60))
    printf "\rWaiting for confirmation... (expires in %d:%02d) " "$R_MINS" "$R_SECS"
  done

  echo ""
  die "Code expired. Run 'uconsole setup' to try again."
}

cmd_push() {
  if [ ! -f "${ENV_FILE}" ]; then
    die "Not configured. Run 'uconsole setup' first."
  fi
  if [ ! -x "${SCRIPTS_DIR}/push-status.sh" ]; then
    die "push-status.sh not found. Run 'uconsole update' to download."
  fi
  "${SCRIPTS_DIR}/push-status.sh"
}

cmd_status() {
  if [ ! -f "${ENV_FILE}" ]; then
    echo "Status: not configured"
    echo "Run 'uconsole setup' to link your device."
    return 0
  fi

  # shellcheck source=/dev/null
  source "${ENV_FILE}"
  echo "Status: configured"
  echo "  API:   ${DEVICE_API_URL:-not set}"
  echo "  Token: ${DEVICE_TOKEN:0:8}...${DEVICE_TOKEN: -4}"
  echo "  Repo:  ${DEVICE_REPO:-not set}"

  # Check scheduling
  if systemctl --user is-active --quiet uconsole-status.timer 2>/dev/null; then
    echo "  Timer: active (systemd, every 5 min)"
  elif crontab -l 2>/dev/null | grep -q "push-status.sh"; then
    echo "  Cron:  active (every 5 min)"
  else
    echo "  Timer: not set"
  fi

  # Last push
  if [ -f /tmp/uconsole-push.log ]; then
    LAST=$(tail -1 /tmp/uconsole-push.log)
    echo "  Last:  ${LAST}"
  fi
}

cmd_unlink() {
  # Stop and disable systemd timer if present
  if systemctl --user is-active --quiet uconsole-status.timer 2>/dev/null; then
    systemctl --user stop uconsole-status.timer
    systemctl --user disable uconsole-status.timer
    echo "Stopped systemd timer"
  fi
  # Remove systemd unit files
  SYSTEMD_DIR="${HOME}/.config/systemd/user"
  rm -f "${SYSTEMD_DIR}/uconsole-status.service" "${SYSTEMD_DIR}/uconsole-status.timer"
  systemctl --user daemon-reload 2>/dev/null

  # Remove cron entry (fallback/legacy)
  if crontab -l 2>/dev/null | grep -q "push-status.sh"; then
    crontab -l 2>/dev/null | grep -v "push-status.sh" | crontab -
    echo "Removed cron job"
  fi

  # Remove config
  if [ -f "${ENV_FILE}" ]; then
    rm -f "${ENV_FILE}"
    echo "Removed config"
  fi

  echo "Device unlinked. Run 'uconsole setup' to reconnect."
}

cmd_update() {
  echo "Updating scripts..."
  mkdir -p "${SCRIPTS_DIR}" "${HOME}/.local/bin"

  curl -fsSL "${BASE_URL}/api/scripts/uconsole" -o "${HOME}/.local/bin/uconsole"
  chmod +x "${HOME}/.local/bin/uconsole"

  curl -fsSL "${BASE_URL}/api/scripts/push-status.sh" -o "${SCRIPTS_DIR}/push-status.sh"
  chmod +x "${SCRIPTS_DIR}/push-status.sh"

  echo "Updated to latest versions."
}

cmd_doctor() {
  echo "uconsole doctor"
  echo ""
  local pass=0 fail=0

  # Config
  if [ -f "${ENV_FILE}" ]; then
    echo "  [OK] Config file exists (${ENV_FILE})"
    pass=$((pass + 1))
    # Check permissions
    PERMS=$(stat -c '%a' "${ENV_FILE}" 2>/dev/null || stat -f '%Lp' "${ENV_FILE}" 2>/dev/null)
    if [ "$PERMS" = "600" ]; then
      echo "  [OK] Config permissions (600)"
      pass=$((pass + 1))
    else
      echo "  [!!] Config permissions are ${PERMS}, should be 600"
      fail=$((fail + 1))
    fi
  else
    echo "  [!!] Config file missing — run 'uconsole setup'"
    fail=$((fail + 1))
  fi

  # Push script
  PUSH_SCRIPT="${SCRIPTS_DIR}/push-status.sh"
  [ -x "${HOME}/uconsole/scripts/push-status.sh" ] && PUSH_SCRIPT="${HOME}/uconsole/scripts/push-status.sh"
  if [ -x "$PUSH_SCRIPT" ]; then
    echo "  [OK] push-status.sh found (${PUSH_SCRIPT})"
    pass=$((pass + 1))
  else
    echo "  [!!] push-status.sh not found or not executable"
    fail=$((fail + 1))
  fi

  # Systemd timer
  if command -v systemctl &>/dev/null; then
    if systemctl --user is-active --quiet uconsole-status.timer 2>/dev/null; then
      echo "  [OK] Status timer active"
      pass=$((pass + 1))
    else
      echo "  [!!] Status timer not active"
      fail=$((fail + 1))
    fi
  elif crontab -l 2>/dev/null | grep -q "push-status.sh"; then
    echo "  [OK] Cron job active (legacy)"
    pass=$((pass + 1))
  else
    echo "  [!!] No timer or cron job for status push"
    fail=$((fail + 1))
  fi

  # Webdash
  if command -v systemctl &>/dev/null && systemctl --user is-active --quiet webdash.service 2>/dev/null; then
    echo "  [OK] Webdash running"
    pass=$((pass + 1))
  else
    echo "  [--] Webdash not running"
  fi

  # Last push (journal or log)
  if command -v journalctl &>/dev/null; then
    LAST_PUSH=$(journalctl --user -u uconsole-status -n 1 --no-pager -q 2>/dev/null | tail -1)
    if [ -n "$LAST_PUSH" ]; then
      echo "  [OK] Last push: ${LAST_PUSH}"
      pass=$((pass + 1))
    fi
  elif [ -f /tmp/uconsole-push.log ]; then
    echo "  [OK] Last push: $(tail -1 /tmp/uconsole-push.log)"
    pass=$((pass + 1))
  fi

  # Network
  if curl -s --max-time 5 -o /dev/null "${BASE_URL}/api/health"; then
    echo "  [OK] uconsole.cloud reachable"
    pass=$((pass + 1))
  else
    echo "  [!!] Cannot reach uconsole.cloud"
    fail=$((fail + 1))
  fi

  echo ""
  echo "  ${pass} passed, ${fail} failed"
}

cmd_restore() {
  REPO_DIR="${HOME}/uconsole"

  if [ ! -d "${REPO_DIR}" ]; then
    echo "Backup repo not found at ${REPO_DIR}"
    echo ""
    echo "To restore, first clone your backup repo:"
    echo "  gh repo clone <user>/uconsole ~/uconsole"
    echo "Then run 'uconsole restore' again."
    return 1
  fi

  if [ ! -f "${REPO_DIR}/restore.sh" ]; then
    echo "restore.sh not found in ${REPO_DIR}"
    return 1
  fi

  echo "Found backup repo at ${REPO_DIR}"
  printf "Run restore.sh --yes? [y/N] "
  read -r CONFIRM
  case "$CONFIRM" in
    [yY]|[yY][eE][sS]) ;;
    *) echo "Cancelled."; return 0 ;;
  esac

  cd "${REPO_DIR}" && bash ./restore.sh --yes

  echo ""
  # Check if cloud is linked
  if [ ! -f "${ENV_FILE}" ]; then
    echo "Restore complete. To connect to uconsole.cloud:"
    echo "  uconsole setup"
  else
    echo "Restore complete. Cloud connection already configured."
  fi
}

cmd_help() {
  echo "uconsole — manage your uconsole.cloud device"
  echo ""
  echo "Commands:"
  echo "  setup    Link this device via code authentication"
  echo "  push     Push status now"
  echo "  status   Show current config and last push"
  echo "  doctor   Diagnose connectivity and configuration"
  echo "  restore  Run restore.sh from backup repo"
  echo "  unlink   Remove config and stop timer"
  echo "  update   Re-download latest scripts"
  echo "  help     Show this help"
}

# ── Main ─────────────────────────────────────────────────

COMMAND="${1:-help}"

case "$COMMAND" in
  setup)   cmd_setup ;;
  push)    cmd_push ;;
  status)  cmd_status ;;
  doctor)  cmd_doctor ;;
  restore) cmd_restore ;;
  unlink)  cmd_unlink ;;
  update)  cmd_update ;;
  help|--help|-h) cmd_help ;;
  *) echo "Unknown command: ${COMMAND}"; cmd_help; exit 1 ;;
esac
