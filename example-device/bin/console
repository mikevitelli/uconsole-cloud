#!/usr/bin/env python3
"""uConsole Command Center — TUI launcher entry point."""

import curses
import os
import sys

# Add module paths
sys.path.insert(0, '/opt/uconsole/lib')
sys.path.insert(0, os.path.expanduser('~/scripts'))

from tui.framework import entry

if __name__ == "__main__":
    os.environ.setdefault("ESCDELAY", "25")
    curses.wrapper(entry)
