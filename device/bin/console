#!/usr/bin/env python3
"""uConsole Command Center — TUI launcher entry point."""

import curses
import os
import sys

# Single runtime source: /opt/uconsole/lib (where the .deb installs).
# For rare dev cases — running a not-yet-installed tree to test — export
# UCONSOLE_DEV_LIB=/path/to/lib. No implicit dev-tree override: the code
# that runs is always whatever was last `make install`'d. "Which tree is
# this?" always has one answer.
_lib = os.environ.get('UCONSOLE_DEV_LIB', '/opt/uconsole/lib')
if os.path.isdir(_lib):
    sys.path.insert(0, _lib)

from tui.framework import entry

if __name__ == "__main__":
    os.environ.setdefault("ESCDELAY", "25")
    curses.wrapper(entry)
